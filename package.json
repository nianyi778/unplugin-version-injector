{
  "name": "unplugin-version-injector",
  "version": "2.3.1",
  "author": "Nian Yi <nianyi778@gmail.com>",
  "license": "MIT",
  "description": "A universal plugin to inject version and build time into HTML (supports Vite, Webpack, Rspack, Rollup, Rolldown)",
  "repository": {
    "type": "git",
    "url": "https://github.com/nianyi778/unplugin-version-injector.git"
  },
  "keywords": [
    "version",
    "injector",
    "unplugin",
    "webpack",
    "vite",
    "rspack",
    "rollup",
    "rolldown"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      },
      "require": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.mts",
        "default": "./dist/webpack.mjs"
      },
      "require": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      }
    },
    "./rspack": {
      "import": {
        "types": "./dist/rspack.d.mts",
        "default": "./dist/rspack.mjs"
      },
      "require": {
        "types": "./dist/rspack.d.ts",
        "default": "./dist/rspack.js"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.mts",
        "default": "./dist/rollup.mjs"
      },
      "require": {
        "types": "./dist/rollup.d.ts",
        "default": "./dist/rollup.js"
      }
    },
    "./rolldown": {
      "import": {
        "types": "./dist/rolldown.d.mts",
        "default": "./dist/rolldown.mjs"
      },
      "require": {
        "types": "./dist/rolldown.d.ts",
        "default": "./dist/rolldown.js"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "unplugin": "^3.3.0"
  },
  "peerDependencies": {
    "@rspack/core": ">=1",
    "rolldown": ">=1.0.0-beta",
    "rollup": "^3 || ^4",
    "vite": ">=3",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "rollup": "^3",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "webpack": "^5",
    "webpack-sources": "^3.2.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "packageManager": "pnpm@10.5.2+sha512.da9dc28cd3ff40d0592188235ab25d3202add8a207afbedc682220e4a0029ffbff4562102b9e6e46b4e3f9e8bd53e6d05de48544b0c57d4b0179e22c76d1199b"
}
